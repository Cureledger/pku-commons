# PKU Commons — environment variables (example)
# Copy this file to `.env` and fill in your own values. Never commit `.env`.
#   cp .env.example .env

# ---------------------------------------------------------------------------
# USDA FoodData Central (FDC) API key
# ---------------------------------------------------------------------------
# Used to fetch per-food phenylalanine (nutrient 508) + protein (203) values
# when building / expanding the benchmark ground-truth test set.
#
# Get a free key (instant) at: https://fdc.nal.usda.gov/api-key-signup.html
# (issued via https://api.data.gov). The literal string DEMO_KEY also works but
# is rate-limited (~30 req/hour, 50/day) and will 429 quickly.
FDC_API_KEY=DEMO_KEY

# Optional: FDC API base URL (rarely needs changing)
# FDC_API_BASE=https://api.nal.usda.gov/fdc/v1
