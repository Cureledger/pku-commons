# =========================================================================
# PKU Commons .gitignore
# Secrets first — never commit credentials. .env.example IS tracked (below).
# =========================================================================

# ---- Secrets / local environment ----
.env
.env.*
!.env.example
*.key
*.pem
*.p12
*.pfx
secrets.*
credentials.*
*.credentials
service-account*.json
*_token
*.token

# ---- Python ----
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
build/
dist/
.venv/
venv/
env/
ENV/
.python-version
.pytest_cache/
.mypy_cache/
.ruff_cache/
.ipynb_checkpoints/
benchmark/results/*.local.json

# ---- Node / JS (for any future app tooling) ----
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
.npm/
.cache/

# ---- Build / bundles / archives ----
*.tar.gz
*.tgz
*.zip
_site/
.jekyll-cache/
.jekyll-metadata

# ---- Editors / IDEs ----
.vscode/
.idea/
*.swp
*.swo
*~
*.sublime-workspace

# ---- OS cruft ----
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# ---- Logs / temp ----
*.log
tmp/
temp/
*.tmp

